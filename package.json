	"private": true,
	"scripts": {
		"build": "npm run build:client",
		"build:client": "vite build",
		"cf-typegen": "wrangler types",
		"check": "npm run build:client && tsc -p tsconfig.worker.json --noEmit && tsc -p tsconfig.app.json --noEmit && wrangler deploy --dry-run",
		"deploy": "wrangler deploy",
		"dev": "npm run build:client && concurrently -k -n CLIENT,WORKER -c magenta,cyan \"vite build --watch\" \"wrangler dev\"",
		"start": "npm run dev",
		"test": "vitest"
	}
