/**
 * Wrangler config for the AI Learning Coach Worker API.
 * The React frontend is built separately and deployed to Cloudflare Pages.
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "llm-chat-app-template",
	"main": "src/index.ts",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
	"observability": {
		"enabled": true
	},
	"ai": {
		"binding": "AI"
	},
	"durable_objects": {
		"bindings": [
			{
				"name": "LEARNING_SESSIONS",
				"class_name": "LearningCoachSessionDurableObject"
			}
		]
	},
	"migrations": [
		{
			"tag": "v2",
			"new_sqlite_classes": ["LearningCoachSessionDurableObject"]
		}
	],
	"workflows": [
		{
			"name": "learning-material-ingestion",
			"binding": "MATERIAL_INGESTION_WORKFLOW",
			"class_name": "MaterialIngestionWorkflow"
		}
	],
	"vars": {
		"CORS_ORIGIN": "*"
	},
	"upload_source_maps": true
}
